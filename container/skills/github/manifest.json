{
  "name": "github",
  "description": "GitHub API — issues, PRs, repos, branches, code search",
  "operations": [
    {
      "name": "setup",
      "description": "Store GitHub personal access token (one-time setup)",
      "params": {
        "token": { "type": "string", "description": "GitHub personal access token" }
      }
    },
    {
      "name": "get_repo",
      "description": "Get repository info",
      "params": {
        "owner": { "type": "string", "description": "Repo owner" },
        "repo": { "type": "string", "description": "Repo name" }
      }
    },
    {
      "name": "list_branches",
      "description": "List branches in a repo",
      "params": {
        "owner": { "type": "string", "description": "Repo owner" },
        "repo": { "type": "string", "description": "Repo name" },
        "per_page": { "type": "number", "description": "Results per page (max 100)", "optional": true }
      }
    },
    {
      "name": "create_branch",
      "description": "Create a branch from a ref",
      "params": {
        "owner": { "type": "string", "description": "Repo owner" },
        "repo": { "type": "string", "description": "Repo name" },
        "branch": { "type": "string", "description": "New branch name" },
        "from_branch": { "type": "string", "description": "Source branch (default: repo default branch)", "optional": true }
      }
    },
    {
      "name": "get_file",
      "description": "Read a file from a repo",
      "params": {
        "owner": { "type": "string", "description": "Repo owner" },
        "repo": { "type": "string", "description": "Repo name" },
        "path": { "type": "string", "description": "File path" },
        "ref": { "type": "string", "description": "Branch/tag/SHA", "optional": true }
      }
    },
    {
      "name": "list_files",
      "description": "List files in a directory (repo tree)",
      "params": {
        "owner": { "type": "string", "description": "Repo owner" },
        "repo": { "type": "string", "description": "Repo name" },
        "path": { "type": "string", "description": "Directory path (empty string for root)", "optional": true },
        "ref": { "type": "string", "description": "Branch/tag/SHA", "optional": true }
      }
    },
    {
      "name": "search_code",
      "description": "Search code across GitHub",
      "params": {
        "query": { "type": "string", "description": "Search query (GitHub code search syntax)" },
        "per_page": { "type": "number", "description": "Results per page (max 100)", "optional": true }
      }
    },
    {
      "name": "list_issues",
      "description": "List issues in a repo",
      "params": {
        "owner": { "type": "string", "description": "Repo owner" },
        "repo": { "type": "string", "description": "Repo name" },
        "state": { "type": "string", "description": "open, closed, or all", "optional": true },
        "labels": { "type": "string", "description": "Comma-separated label names", "optional": true },
        "per_page": { "type": "number", "description": "Results per page (max 100)", "optional": true }
      }
    },
    {
      "name": "get_issue",
      "description": "Get a single issue with comments",
      "params": {
        "owner": { "type": "string", "description": "Repo owner" },
        "repo": { "type": "string", "description": "Repo name" },
        "issue_number": { "type": "number", "description": "Issue number" }
      }
    },
    {
      "name": "create_issue",
      "description": "Create an issue",
      "params": {
        "owner": { "type": "string", "description": "Repo owner" },
        "repo": { "type": "string", "description": "Repo name" },
        "title": { "type": "string", "description": "Issue title" },
        "body": { "type": "string", "description": "Issue body (markdown)", "optional": true },
        "labels": { "type": "string", "description": "Comma-separated label names", "optional": true }
      }
    },
    {
      "name": "comment_on_issue",
      "description": "Add a comment to an issue or PR",
      "params": {
        "owner": { "type": "string", "description": "Repo owner" },
        "repo": { "type": "string", "description": "Repo name" },
        "issue_number": { "type": "number", "description": "Issue or PR number" },
        "body": { "type": "string", "description": "Comment body (markdown)" }
      }
    },
    {
      "name": "search_issues",
      "description": "Search issues and PRs across GitHub",
      "params": {
        "query": { "type": "string", "description": "Search query (GitHub issues search syntax)" },
        "per_page": { "type": "number", "description": "Results per page (max 100)", "optional": true }
      }
    },
    {
      "name": "list_prs",
      "description": "List pull requests in a repo",
      "params": {
        "owner": { "type": "string", "description": "Repo owner" },
        "repo": { "type": "string", "description": "Repo name" },
        "state": { "type": "string", "description": "open, closed, or all", "optional": true },
        "per_page": { "type": "number", "description": "Results per page (max 100)", "optional": true }
      }
    },
    {
      "name": "get_pr",
      "description": "Get a pull request with details",
      "params": {
        "owner": { "type": "string", "description": "Repo owner" },
        "repo": { "type": "string", "description": "Repo name" },
        "pull_number": { "type": "number", "description": "PR number" }
      }
    },
    {
      "name": "create_pr",
      "description": "Create a pull request",
      "params": {
        "owner": { "type": "string", "description": "Repo owner" },
        "repo": { "type": "string", "description": "Repo name" },
        "title": { "type": "string", "description": "PR title" },
        "body": { "type": "string", "description": "PR body (markdown)", "optional": true },
        "head": { "type": "string", "description": "Branch with changes" },
        "base": { "type": "string", "description": "Branch to merge into" }
      }
    },
    {
      "name": "merge_pr",
      "description": "Merge a pull request",
      "params": {
        "owner": { "type": "string", "description": "Repo owner" },
        "repo": { "type": "string", "description": "Repo name" },
        "pull_number": { "type": "number", "description": "PR number" },
        "merge_method": { "type": "string", "description": "merge, squash, or rebase", "optional": true }
      }
    },
    {
      "name": "list_pr_files",
      "description": "List files changed in a PR",
      "params": {
        "owner": { "type": "string", "description": "Repo owner" },
        "repo": { "type": "string", "description": "Repo name" },
        "pull_number": { "type": "number", "description": "PR number" }
      }
    },
    {
      "name": "list_pr_comments",
      "description": "List review comments on a PR",
      "params": {
        "owner": { "type": "string", "description": "Repo owner" },
        "repo": { "type": "string", "description": "Repo name" },
        "pull_number": { "type": "number", "description": "PR number" }
      }
    },
    {
      "name": "create_pr_review",
      "description": "Submit a PR review",
      "params": {
        "owner": { "type": "string", "description": "Repo owner" },
        "repo": { "type": "string", "description": "Repo name" },
        "pull_number": { "type": "number", "description": "PR number" },
        "body": { "type": "string", "description": "Review body" },
        "event": { "type": "string", "description": "APPROVE, REQUEST_CHANGES, or COMMENT" }
      }
    }
  ]
}
